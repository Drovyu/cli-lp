    const commands = [
      { id: 'create', cmd: 'dvyu create [path]', example: 'dvyu create ./dist',
        ja: 'ビルド済みディレクトリ（または単一HTML）から暗号化プレビューURLを作成します。パス省略時は dist → index.html の順に探します。サポーターは --permanence で長期保持できます。',
        en: 'Create an encrypted preview URL from a build directory or a single HTML file. Without a path it tries dist, then index.html. Supporters can add --permanence to keep it longer.' },
      { id: 'preview', cmd: 'dvyu preview [project]', example: 'dvyu preview ./my-app',
        ja: 'Astro / Vite / Storybook を自動判別し、ビルドしてからプレビューを作成します。同じ出力先の古いプレビューは削除して作り直します。--out-dir で出力先を指定できます。',
        en: 'Detects Astro, Vite, or Storybook, builds the project, then creates a preview. Replaces an existing preview for the same output path. Use --out-dir to override the output directory.' },
      { id: 'update', cmd: 'dvyu update [id] [path]', example: 'dvyu update ./dist',
        ja: 'URLを変えずに、最新のローカルプレビューの中身を差し替えます。送ったリンクはそのまま使えます。',
        en: 'Replace the content of your latest preview without changing its URL. Links you already shared keep working.' },
      { id: 'list', cmd: 'dvyu list', example: 'dvyu list',
        ja: 'このデバイスで作成した有効なプレビューのURL・状態・期限を一覧表示します。期限切れも含める場合は dvyu list all。',
        en: 'List active previews created on this device with their URLs, state, and expiry. Run dvyu list all to include expired ones.' },
    ]

    /* Demo scripts for the interactive hero terminal */
    const demos = {
      create: { lines: [
        { t: 'check', text: '24 files encrypted (3.8 MB)' },
        { t: 'url', text: 'https://preview.drovyu.com/p/8Qm2kY#k=…' },
        { t: 'dim', en: 'Expires in 48 hours', ja: '48時間後に失効' },
      ] },
      preview: { lines: [
        { t: 'bullet', en: 'Detected Astro project', ja: 'Astro プロジェクトを検出' },
        { t: 'check', text: 'astro build --base ./' },
        { t: 'url', text: 'https://preview.drovyu.com/p/8Qm2kY#k=…' },
      ] },
      update: { lines: [
        { t: 'check', en: '24 files re-encrypted', ja: '24 ファイルを再暗号化' },
        { t: 'check', en: 'Same URL, new content', ja: 'URLはそのまま、中身だけ更新' },
      ] },
      list: { lines: [
        { t: 'row', text: '8Qm2kY  preview.drovyu.com/p/8Qm2kY  47h left' },
        { t: 'row', text: '3Xw9pL  preview.drovyu.com/p/3Xw9pL  12h left' },
      ] },
    }

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const delay = (ms) => new Promise((resolve) => setTimeout(resolve, ms))

    let currentLang = localStorage.getItem('dvyu-lang') || (navigator.language && navigator.language.toLowerCase().startsWith('ja') ? 'ja' : 'en')

    function applyLanguage(lang) {
      currentLang = lang
      localStorage.setItem('dvyu-lang', lang)
      document.documentElement.lang = lang
      document.documentElement.classList.toggle('lang-ja', lang === 'ja')
      document.documentElement.classList.toggle('lang-en', lang === 'en')
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const value = dict[lang][el.dataset.i18n]
        if (value) el.textContent = value
      })
      document.querySelectorAll('[data-i18n-html]').forEach((el) => {
        const value = dict[lang][el.dataset.i18nHtml]
        if (value) el.innerHTML = value
      })
      document.querySelectorAll('.lang-switch [data-lang]').forEach((el) => {
        el.classList.toggle('active', el.dataset.lang === lang)
      })
      renderDemoMeta()
      runDemo(activeDemoId)
    }

    document.querySelectorAll('.lang-switch [data-lang]').forEach((el) => {
      el.addEventListener('click', () => applyLanguage(el.dataset.lang))
    })

    /* -------------------- Copy to clipboard + toast -------------------- */
    const toast = document.getElementById('toast')
    let toastTimer = null

    function copyText(value) {
      if (!value) return
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(value).catch(() => {})
      }
      toast.classList.add('is-visible')
      if (toastTimer) clearTimeout(toastTimer)
      toastTimer = setTimeout(() => toast.classList.remove('is-visible'), 1600)
    }

    document.querySelectorAll('[data-copy]').forEach((button) => {
      button.addEventListener('click', () => copyText(button.dataset.copy))
    })

    /* ----------------------------- Install tabs ----------------------------- */
    const installCommands = {
      pnpm: 'pnpm add -g dvyu',
      npm: 'npm install -g dvyu',
      npx: 'npx dvyu create ./dist',
    }

    const installTabButtons = document.querySelectorAll('.install-tab-list button')
    const installTabCode = document.getElementById('install-tab-code')
    const installTabCopy = document.getElementById('install-tab-copy')

    installTabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        installTabButtons.forEach((item) => item.classList.remove('active'))
        button.classList.add('active')
        const command = installCommands[button.dataset.tab]
        installTabCode.textContent = command
        installTabCopy.dataset.copy = command
      })
    })

    /* ------------------- Interactive hero terminal (demos) ------------------ */
    const demoBody = document.getElementById('demo-body')
    const demoTabs = document.querySelectorAll('#demo-tabs button')
    const demoDesc = document.getElementById('demo-desc')
    const demoCopy = document.getElementById('demo-copy')
    let activeDemoId = 'create'
    let demoCycle = 0

    function demoLineText(line) {
      return line.text || (currentLang === 'ja' ? line.ja : line.en) || ''
    }

    function demoLineHtml(line) {
      const text = demoLineText(line)
      if (line.t === 'check') return '<p class="terminal-status"><span class="glyph">✓</span><span>' + text + '</span></p>'
      if (line.t === 'url') return '<p class="terminal-status"><span class="glyph">✓</span><span class="url-text">' + text + '</span></p>'
      if (line.t === 'bullet') return '<p class="terminal-status"><span class="glyph is-bullet">●</span><span>' + text + '</span></p>'
      if (line.t === 'dim') return '<p class="terminal-status is-dim">' + text + '</p>'
      return '<p class="terminal-status is-row">' + text + '</p>'
    }

    async function runDemo(id) {
      const cycle = ++demoCycle
      const demo = demos[id]
      const command = commands.find((item) => item.id === id)
      const cmdStr = demo.cmd || command.example
      demoBody.innerHTML = ''

      const line = document.createElement('p')
      line.className = 'terminal-line'
      line.innerHTML = '<span class="prompt-char">$</span><span class="cmd-text"></span><span class="terminal-cursor"></span>'
      demoBody.appendChild(line)
      const cmdText = line.querySelector('.cmd-text')
      const cursor = line.querySelector('.terminal-cursor')

      if (prefersReducedMotion) {
        cmdText.textContent = cmdStr
        cursor.hidden = true
        demo.lines.forEach((item) => demoBody.insertAdjacentHTML('beforeend', demoLineHtml(item)))
        demoBody.insertAdjacentHTML('beforeend', '<p class="terminal-line"><span class="prompt-char">$</span></p>')
        return
      }

      for (let i = 0; i < cmdStr.length; i += 1) {
        if (cycle !== demoCycle) return
        cmdText.textContent = cmdStr.slice(0, i + 1)
        await delay(60)
      }
      await delay(350)
      for (const item of demo.lines) {
        if (cycle !== demoCycle) return
        demoBody.insertAdjacentHTML('beforeend', demoLineHtml(item))
        await delay(300)
      }
      if (cycle !== demoCycle) return
      cursor.hidden = true
      demoBody.insertAdjacentHTML('beforeend', '<p class="terminal-line"><span class="prompt-char">$</span><span class="terminal-cursor"></span></p>')
    }

    function renderDemoMeta() {
      const command = commands.find((item) => item.id === activeDemoId)
      demoDesc.textContent = command[currentLang]
      demoCopy.dataset.copy = command.example
    }

    demoTabs.forEach((button) => {
      button.addEventListener('click', () => {
        if (button.dataset.demo === activeDemoId) return
        demoTabs.forEach((item) => item.classList.remove('active'))
        button.classList.add('active')
        activeDemoId = button.dataset.demo
        renderDemoMeta()
        runDemo(activeDemoId)
      })
    })

    /* --------------------------- Scrollytelling ----------------------------- */
    const scrollySection = document.getElementById('start')
    const scrollyBody = document.getElementById('scrolly-body')
    const browserCard = document.getElementById('browser-card')
    const scrollyCaptions = document.querySelectorAll('.scrolly-caption')

    const SC_CMD1 = 'pnpm add -g dvyu'
    const SC_CMD2 = 'dvyu create ./dist'

    scrollyBody.innerHTML =
      '<p class="terminal-line"><span class="prompt-char">$</span><span class="cmd-text" id="sc-c1"></span><span class="terminal-cursor" id="sc-k1"></span></p>' +
      '<p class="terminal-status is-dim" id="sc-o1" hidden>+ dvyu 0.1.0</p>' +
      '<p class="terminal-line" id="sc-l2" hidden><span class="prompt-char">$</span><span class="cmd-text" id="sc-c2"></span><span class="terminal-cursor" id="sc-k2"></span></p>' +
      '<p class="terminal-status" id="sc-o2" hidden><span class="glyph">✓</span><span>24 files encrypted (3.8 MB)</span></p>' +
      '<p class="terminal-status" id="sc-o3" hidden><span class="glyph">✓</span><span class="url-text">https://preview.drovyu.com/p/8Qm2kY#k=…</span></p>'

    const sc = {
      c1: document.getElementById('sc-c1'),
      k1: document.getElementById('sc-k1'),
      o1: document.getElementById('sc-o1'),
      l2: document.getElementById('sc-l2'),
      c2: document.getElementById('sc-c2'),
      k2: document.getElementById('sc-k2'),
      o2: document.getElementById('sc-o2'),
      o3: document.getElementById('sc-o3'),
    }

    let scrollyStatic = false
    const narrowViewport = window.matchMedia('(max-width: 767px)')

    function renderScrolly(p) {
      const t1 = Math.min(Math.max(p / 0.26, 0), 1)
      sc.c1.textContent = SC_CMD1.slice(0, Math.floor(SC_CMD1.length * t1))
      sc.o1.hidden = p < 0.28
      const step2 = p >= 0.3
      sc.l2.hidden = !step2
      const t2 = Math.min(Math.max((p - 0.32) / 0.18, 0), 1)
      sc.c2.textContent = step2 ? SC_CMD2.slice(0, Math.floor(SC_CMD2.length * t2)) : ''
      sc.o2.hidden = p < 0.55
      sc.o3.hidden = p < 0.62
      sc.o3.classList.toggle('is-highlight', p >= 0.65)
      const done = p >= 0.99
      sc.k1.hidden = step2 || done
      sc.k2.hidden = !step2 || done
      browserCard.classList.toggle('visible', p >= 0.65)
      const active = p < 0.3 ? 0 : p < 0.65 ? 1 : 2
      scrollyCaptions.forEach((el, i) => el.classList.toggle('active', scrollyStatic || i === active))
    }

    function updateScrolly() {
      if (scrollyStatic) return
      const top = scrollySection.offsetTop
      const range = scrollySection.offsetHeight - window.innerHeight
      const p = Math.min(Math.max((window.scrollY - top) / Math.max(range, 1), 0), 1)
      renderScrolly(p)
    }

    function evalScrollyMode() {
      scrollyStatic = prefersReducedMotion || narrowViewport.matches
      scrollySection.classList.toggle('is-static', scrollyStatic)
      if (scrollyStatic) {
        renderScrolly(1)
      } else {
        updateScrolly()
      }
    }

    window.addEventListener('resize', evalScrollyMode, { passive: true })
    if (narrowViewport.addEventListener) narrowViewport.addEventListener('change', evalScrollyMode)

    /* ---------------------- Unified scroll frame (rAF) ---------------------- */
    const navbar = document.getElementById('navbar')
    const navProgress = document.getElementById('nav-progress')
    let scrollFrame = 0

    function onScrollFrame() {
      scrollFrame = 0
      const y = window.scrollY
      navbar.classList.toggle('is-scrolled', y > 12)
      const docRange = document.documentElement.scrollHeight - window.innerHeight
      navProgress.style.transform = 'scaleX(' + (docRange > 0 ? Math.min(y / docRange, 1) : 0).toFixed(4) + ')'
      updateScrolly()
    }

    window.addEventListener('scroll', () => {
      if (!scrollFrame) scrollFrame = requestAnimationFrame(onScrollFrame)
    }, { passive: true })

    evalScrollyMode()
    onScrollFrame()

    /* ------------------------------ Reveal -------------------------------- */
    const countedElements = new WeakSet()

    function formatCount(value) {
      return value.toLocaleString(undefined, { maximumFractionDigits: 3 })
    }

    function animateCount(el) {
      const target = Number(el.dataset.count) || 0
      const suffix = el.dataset.suffix || ''
      const fractionDigits = Number.isInteger(target) ? 0 : 3
      const start = performance.now()
      const duration = 1200
      function frame(now) {
        const progress = Math.min((now - start) / duration, 1)
        const eased = 1 - Math.pow(1 - progress, 3)
        const value = fractionDigits === 0
          ? Math.floor(target * eased)
          : Number((target * eased).toFixed(fractionDigits))
        el.textContent = formatCount(value) + suffix
        if (progress < 1) {
          requestAnimationFrame(frame)
        } else {
          el.textContent = formatCount(target) + suffix
        }
      }
      if (prefersReducedMotion) {
        el.textContent = formatCount(target) + suffix
      } else {
        requestAnimationFrame(frame)
      }
    }

    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return
          entry.target.classList.add('is-visible')
          if (entry.target.dataset.loaded === 'true' && !countedElements.has(entry.target)) {
            countedElements.add(entry.target)
            animateCount(entry.target)
          }
        })
      },
      { threshold: 0.2 },
    )

    document.querySelectorAll('.reveal, [data-count]').forEach((el) => revealObserver.observe(el))

    async function loadPublicStats() {
      const elements = {
        previews: document.querySelector('[data-stat="previews"]'),
        transferred: document.querySelector('[data-stat="transferred"]'),
        devices: document.querySelector('[data-stat="devices"]'),
      }
      try {
        const response = await fetch('https://stats.preview.drovyu.com/stats.json')
        if (!response.ok) throw new Error('Could not load public stats')
        const stats = await response.json()
        const values = {
          previews: Number(stats.previewsCreated),
          transferred: Number(stats.encryptedGigabytesPublished),
          devices: Number(stats.devices),
        }
        Object.entries(elements).forEach(([key, el]) => {
          const value = values[key]
          if (!el || !Number.isFinite(value) || value < 0) throw new Error('Invalid public stats')
          el.dataset.count = String(value)
          el.dataset.loaded = 'true'
          if (el.classList.contains('is-visible')) {
            countedElements.add(el)
            animateCount(el)
          }
        })
      } catch {
        Object.values(elements).forEach((el) => {
          if (el) el.textContent = '—'
        })
      }
    }

    loadPublicStats()

    applyLanguage(currentLang)
  </script>
</BaseLayout>
