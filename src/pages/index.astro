---
import {
  ArrowRight,
  Check,
  Code2,
  Copy,
  ExternalLink,
} from '@lucide/astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import SiteHeader from '../components/SiteHeader.astro'
import LogoMark from '../components/LogoMark.astro'

const LINKS = {
  discord: 'https://discord.gg/4SGxzSbaaD',
  x: 'https://x.com/drovyu',
  github: 'https://github.com/Drovyu/preview-cli',
  kofi: 'https://ko-fi.com/drovyu',
}

const install = 'pnpm add -g dvyu'

const features = [
  { chip: 'AES-GCM', key: 'f1', title: 'アップロード前に暗号化', body: 'ファイルは AES-GCM でローカル暗号化してから送信。復号キーはURLフラグメントにあり、サーバー側はファイル名すら見えません。' },
  { chip: 'dvyu preview', key: 'f2', title: 'ビルドも任せられる', body: 'dvyu preview が Astro / Vite / Storybook を自動判別。ビルダーに合わせて出力し、そのままアップロードします。' },
  { chip: 'dvyu update', key: 'f3', title: 'URLを変えずに更新', body: '修正したら dvyu update。同じURLのまま中身だけ差し替わるので、送ったリンクを貼り直す必要がありません。' },
  { chip: '--permanence', key: 'f4', title: '期限つきで、あと腐れなく', body: 'プレビューは48時間で自動失効。--permanence を付ければ、アクセスが1ヶ月途切れるまで残せます。' },
  { chip: 'dvyu create ./file.html', key: 'f5', title: 'HTML 1枚からでも', body: 'dvyu create ./example.html のように、単一のHTMLファイルからもプレビューを作れます。ちょっとしたモックの共有に。' },
  { chip: 'dvyu usage', key: 'f6', title: '使用量がすぐわかる', body: 'dvyu usage で使用中の容量を、dvyu list で有効なプレビューと期限を確認。上限は 100MB・20 プレビューです。' },
]

const commands = [
  { id: 'create', cmd: 'dvyu create [path]', example: 'dvyu create ./dist',
    ja: 'ビルド済みディレクトリ（または単一HTML）から暗号化プレビューURLを作成します。パス省略時は dist → index.html の順に探します。サポーターは --permanence で長期保持できます。',
    en: 'Create an encrypted preview URL from a build directory or a single HTML file. Without a path it tries dist, then index.html. Supporters can add --permanence to keep it longer.' },
  { id: 'preview', cmd: 'dvyu preview [project]', example: 'dvyu preview ./my-app',
    ja: 'Astro / Vite / Storybook を自動判別し、ビルドしてからプレビューを作成します。同じ出力先の古いプレビューは削除して作り直します。--out-dir で出力先を指定できます。',
    en: 'Detects Astro, Vite, or Storybook, builds the project, then creates a preview. Replaces an existing preview for the same output path. Use --out-dir to override the output directory.' },
  { id: 'update', cmd: 'dvyu update [id] [path]', example: 'dvyu update ./dist',
    ja: 'URLを変えずに、最新のローカルプレビューの中身を差し替えます。送ったリンクはそのまま使えます。',
    en: 'Replace the content of your latest preview without changing its URL. Links you already shared keep working.' },
  { id: 'list', cmd: 'dvyu list', example: 'dvyu list',
    ja: 'このデバイスで作成した有効なプレビューのURL・状態・期限を一覧表示します。期限切れも含める場合は dvyu list all。',
    en: 'List active previews created on this device with their URLs, state, and expiry. Run dvyu list all to include expired ones.' },
]

const fileTypes = ['.html', '.htm', '.md', '.txt', '.json', '.xml', '.map', '.css', '.js', '.mjs', '.cjs', '.png', '.jpg', '.jpeg', '.gif', '.svg', '.webp', '.ico', '.avif', '.woff', '.woff2', '.ttf', '.otf', '.mp4', '.webm', '.mp3', '.wav', '.pdf']
const fileTypesReversed = [...fileTypes].reverse()
---

<BaseLayout>
  <SiteHeader />

  <main>
    <section class="hero" id="top">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-inner">
        <div class="reveal">
          <div class="hero-eyebrow" data-i18n="hero-eyebrow">Drovyu Preview CLI</div>
          <h1 class="hero-title" data-i18n-html="hero-title">静的ビルドを、<br />そのまま<em>共有URL</em>に。</h1>
          <p class="hero-copy" data-i18n="hero-copy">dvyu create を実行するだけで、暗号化された一時プレビューURLが手に入ります。デプロイもアカウント登録も不要。ターミナルだけで完結します。</p>
          <div class="install-bar">
            <div class="install-tab-list" role="tablist" aria-label="Package manager">
              <button type="button" class="active" data-tab="pnpm">pnpm</button>
              <button type="button" data-tab="npm">npm</button>
              <button type="button" data-tab="npx">npx</button>
            </div>
            <div class="install-line">
              <span class="install-prompt">$</span>
              <code id="install-tab-code">{install}</code>
              <button type="button" id="install-tab-copy" data-copy={install} aria-label="Copy">
                <Copy size={15} strokeWidth={2} />
                <span data-i18n="copy">コピー</span>
              </button>
            </div>
          </div>
          <div class="hero-actions">
            <a href="/docs" class="hero-cta">
              <span data-i18n="hero-cta">コマンド一覧を見る</span>
              <ArrowRight size={15} strokeWidth={2.2} />
            </a>
            <span class="hero-req">
              <Check size={14} strokeWidth={2.4} />
              <span data-i18n="hero-req">Node.js 20 以上</span>
            </span>
          </div>
        </div>

        <div class="terminal-demo reveal" id="terminal-demo" style="--delay:140ms">
          <div class="demo-tabs" id="demo-tabs" role="tablist" aria-label="Commands">
            {commands.map((command, index) => (
              <button type="button" class={index === 0 ? 'active' : ''} data-demo={command.id}>{command.id}</button>
            ))}
          </div>
          <div class="terminal-card">
            <div class="terminal-titlebar">
              <div class="terminal-dots"><i></i><i></i><i></i></div>
              <span>dvyu — zsh</span>
            </div>
            <div class="terminal-body" id="demo-body"></div>
          </div>
          <div class="demo-meta">
            <p id="demo-desc"></p>
            <div class="demo-meta-actions">
              <button type="button" id="demo-copy" data-copy={commands[0].example} aria-label="Copy example">
                <Copy size={14} strokeWidth={2} />
                <span data-i18n="copy">コピー</span>
              </button>
              <a href="/docs" class="demo-docs-link">
                <span data-i18n="all-commands">すべてのコマンドを見る</span>
                <ArrowRight size={14} strokeWidth={2.2} />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="stats" id="stats">
      <div class="stats-inner">
        <p class="section-label reveal" data-i18n="stats-label">これまでの利用状況</p>
        <div class="stat-grid">
          <div class="stat-card reveal">
            <span class="stat-value" data-stat="previews" data-count="0" data-suffix="">0</span>
            <span class="stat-label" data-i18n="stat-previews">作成されたプレビュー</span>
          </div>
          <div class="stat-card reveal" style="--delay:120ms">
            <span class="stat-value" data-stat="transferred" data-count="0" data-suffix=" GB">0</span>
            <span class="stat-label" data-i18n="stat-transferred">配信した暗号化データ</span>
          </div>
          <div class="stat-card reveal" style="--delay:240ms">
            <span class="stat-value" data-stat="devices" data-count="0" data-suffix="">0</span>
            <span class="stat-label" data-i18n="stat-devices">利用中のデバイス</span>
          </div>
        </div>
      </div>
    </section>

    <section class="scrolly" id="start">
      <div class="scrolly-stage">
        <div class="section-inner">
          <div class="scrolly-head">
            <p class="section-label" data-i18n="start-label">はじめかた</p>
            <h2 class="section-title" data-i18n-html="start-title">インストールして、<br /><em>つくって、送る。</em></h2>
          </div>
          <div class="scrolly-grid">
            <div class="terminal-card scrolly-terminal">
              <div class="terminal-titlebar">
                <div class="terminal-dots"><i></i><i></i><i></i></div>
                <span>getting-started — zsh</span>
              </div>
              <div class="terminal-body" id="scrolly-body"></div>
            </div>
            <div class="scrolly-captions">
              <div class="scrolly-caption active" data-step="0">
                <span class="cap-num">01</span>
                <div class="cap-text">
                  <h3 data-i18n="step1-title">インストール</h3>
                  <p data-i18n="step1-body">pnpm でも npm でも。npx なら、インストールせずに一度だけ試せます。</p>
                </div>
              </div>
              <div class="scrolly-caption" data-step="1">
                <span class="cap-num">02</span>
                <div class="cap-text">
                  <h3 data-i18n="step2-title">プレビューを作成</h3>
                  <p data-i18n="step2-body">ビルド済みの dist を渡すと、ローカルで暗号化してからアップロードします。</p>
                </div>
              </div>
              <div class="scrolly-caption" data-step="2">
                <span class="cap-num">03</span>
                <div class="cap-text">
                  <h3 data-i18n="step3-title">URLを送る</h3>
                  <p data-i18n="step3-body">発行されたURLを相手に送るだけ。48時間で自動的に失効します。</p>
                </div>
              </div>
              <div class="browser-card" id="browser-card" aria-hidden="true">
                <div class="browser-bar">
                  <span class="browser-dots"><i></i><i></i><i></i></span>
                  <span class="browser-url">preview.drovyu.com/p/8Qm2kY</span>
                </div>
                <div class="browser-body">
                  <span class="skel skel-title"></span>
                  <span class="skel w90"></span>
                  <span class="skel w75"></span>
                  <span class="skel skel-block"></span>
                  <span class="skel w60"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section is-alt" id="features">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="section-label" data-i18n="features-label">機能</p>
          <h2 class="section-title" data-i18n-html="features-title">デプロイするほどじゃない。<br />でも<em>見せたい</em>ときのために。</h2>
        </div>
        <div class="feature-grid">
          {features.map((feature, index) => (
            <article class="feature-card reveal" style={`--delay:${(index % 3) * 90}ms`}>
              <code class="feature-chip">{feature.chip}</code>
              <h3 data-i18n={`${feature.key}-title`}>{feature.title}</h3>
              <p data-i18n={`${feature.key}-body`}>{feature.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section is-white" id="filetypes">
      <div class="section-inner">
        <div class="filetypes">
          <div class="marquee">
            <div class="marquee-row">
              <div class="marquee-track">
                {[...fileTypes, ...fileTypes].map((ext) => <span class="file-chip">{ext}</span>)}
              </div>
            </div>
            <div class="marquee-row reverse">
              <div class="marquee-track">
                {[...fileTypesReversed, ...fileTypesReversed].map((ext) => <span class="file-chip">{ext}</span>)}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section is-alt" id="pricing">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="section-label" data-i18n="pricing-label">料金</p>
          <h2 class="section-title" data-i18n-html="pricing-title">無料で使えます。<br /><em>応援</em>もできます。</h2>
          <p class="section-copy" data-i18n="pricing-copy">課金プランはありません。Ko-fi で支援してくれた方には、金額を問わず、お礼として30日間の特典が付きます。</p>
        </div>
        <div class="pricing-grid">
          <div class="plan-card reveal">
            <h3 class="plan-name" data-i18n="plan-free-name">無料</h3>
            <div class="plan-price" data-i18n="plan-free-price">¥0</div>
            <p class="plan-desc" data-i18n="plan-free-desc">インストールすればそのまま使えます。</p>
            <ul class="plan-list">
              <li><Check size={15} strokeWidth={2.4} /><span data-i18n="plan-free-1">1デバイス</span></li>
              <li><Check size={15} strokeWidth={2.4} /><span data-i18n="plan-free-2">アクティブ容量 100MB</span></li>
              <li><Check size={15} strokeWidth={2.4} /><span data-i18n="plan-free-3">同時プレビュー 20件</span></li>
              <li><Check size={15} strokeWidth={2.4} /><span data-i18n="plan-free-4">有効期限 48時間</span></li>
            </ul>
          </div>
          <div class="plan-card is-supporter reveal" style="--delay:120ms">
            <span class="plan-badge">ko-fi</span>
            <h3 class="plan-name" data-i18n="plan-sup-name">サポーター</h3>
            <div class="plan-price" data-i18n="plan-sup-price">金額は自由</div>
            <p class="plan-desc" data-i18n="plan-sup-desc">Ko-fi での支援1回につき、30日間の特典。</p>
            <ul class="plan-list">
              <li><Check size={15} strokeWidth={2.4} /><span data-i18n="plan-sup-1">2デバイスで有効</span></li>
              <li><Check size={15} strokeWidth={2.4} /><span data-i18n="plan-sup-2">アクティブ容量 300MB</span></li>
              <li><Check size={15} strokeWidth={2.4} /><span data-i18n="plan-sup-3">アクティブ数無制限</span></li>
              <li><Check size={15} strokeWidth={2.4} /><span data-i18n="plan-sup-4">--permanence でアクセスが続く限り保持（30日アクセスがなければ削除）</span></li>
              <li><Check size={15} strokeWidth={2.4} /><span data-i18n="plan-sup-5">--ttl で有効期限を自由に設定（1時間〜30日）</span></li>
            </ul>
            <a class="plan-cta" href={LINKS.kofi} target="_blank" rel="noreferrer">
              <span data-i18n="plan-sup-cta">Ko-fi で応援する</span>
              <ExternalLink size={14} strokeWidth={2.2} />
            </a>
          </div>
        </div>
        <p class="pricing-note reveal">
          <code>$ dvyu supporter</code>
          <span data-i18n="plan-sup-note">特典の有効化は dvyu supporter から。</span>
        </p>
      </div>
    </section>

    <section class="closing" id="community">
      <div class="closing-glow" aria-hidden="true"></div>
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="section-label" data-i18n="community-label">コミュニティ</p>
          <h2 class="section-title" data-i18n-html="community-title">作っている人と、<em>直接</em>話せます。</h2>
          <p class="section-copy" data-i18n="community-copy">不具合報告・要望・質問は Discord へ。開発の進捗は X で発信しています。</p>
        </div>
        <div class="community-grid">
          <a class="community-card is-discord reveal" href={LINKS.discord} target="_blank" rel="noreferrer">
            <div class="community-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                <path d="M20.317 4.369a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.211.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.045-.32 13.579.099 18.057a.082.082 0 0 0 .031.056 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.927 1.793 8.18 1.793 12.061 0a.074.074 0 0 1 .078.01c.12.099.246.197.373.291a.077.077 0 0 1-.006.128 12.3 12.3 0 0 1-1.873.892.076.076 0 0 0-.04.106c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.876 19.876 0 0 0 6.002-3.03.077.077 0 0 0 .032-.055c.5-5.177-.838-9.674-3.548-13.66a.061.061 0 0 0-.031-.028ZM8.02 15.331c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.418 2.157-2.418 1.21 0 2.176 1.094 2.157 2.418 0 1.334-.955 2.419-2.157 2.419Zm7.974 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.418 2.157-2.418 1.21 0 2.176 1.094 2.157 2.418 0 1.334-.947 2.419-2.157 2.419Z" />
              </svg>
            </div>
            <h3>Discord</h3>
            <p data-i18n="discord-body">質問・バグ報告・雑談はこちら。開発者が直接返信します。</p>
            <ExternalLink class="community-arrow" size={16} strokeWidth={2} />
          </a>
          <a class="community-card is-x reveal" style="--delay:120ms" href={LINKS.x} target="_blank" rel="noreferrer">
            <div class="community-icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25h6.826l4.713 6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117Z" />
              </svg>
            </div>
            <h3>X</h3>
            <p data-i18n="x-body">新機能や開発の進捗を発信しています。</p>
            <ExternalLink class="community-arrow" size={16} strokeWidth={2} />
          </a>
        </div>
        <div class="closing-install reveal">
          <span class="install-prompt">$</span>
          <code>{install}</code>
          <button type="button" data-copy={install} aria-label="Copy">
            <Copy size={15} strokeWidth={2} />
            <span data-i18n="copy">コピー</span>
          </button>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-left">
          <a href="#top" class="footer-logo"><LogoMark size={16} />dvyu</a>
          <span class="footer-copyright">© 2026 Drovyu</span>
          <span class="footer-note" data-i18n="footer-note">静的ビルドのための、暗号化プレビュー。</span>
        </div>
        <div class="footer-links">
          <a href={LINKS.github} target="_blank" rel="noreferrer">
            <Code2 size={15} strokeWidth={2} />
            GitHub
          </a>
          <a href="/docs">Docs</a>
          <a href="/help" data-i18n="footer-help">ヘルプ</a>
        </div>
      </div>
    </footer>
  </main>

  <div class="toast" id="toast" role="status" aria-live="polite">
    <Check size={16} strokeWidth={2.4} />
    <span id="toast-text" data-i18n="copied">コピーしました</span>
  </div>

  <script>
    const dict = {
      ja: {
        'nav-features': '機能',
        'nav-commands': 'コマンド',
        'nav-pricing': '料金',
        'nav-docs': 'ドキュメント',
        'nav-help': 'ヘルプ',
        'nav-community': 'コミュニティ',
        'hero-eyebrow': 'Drovyu Preview CLI',
        'hero-title': '静的ビルドを、<br>そのまま<em>共有URL</em>に。',
        'hero-copy': 'dvyu create を実行するだけで、暗号化された一時プレビューURLが手に入ります。デプロイもアカウント登録も不要。ターミナルだけで完結します。',
        'hero-cta': 'コマンド一覧を見る',
        'hero-req': 'Node.js 20 以上',
        'all-commands': 'すべてのコマンドを見る',
        'copy': 'コピー',
        'copied': 'コピーしました',
        'stats-label': 'これまでの利用状況',
        'stat-previews': '作成されたプレビュー',
        'stat-transferred': '配信した暗号化データ',
        'stat-devices': '利用中のデバイス',
        'start-label': 'はじめかた',
        'start-title': 'インストールして、<br><em>つくって、送る。</em>',
        'step1-title': 'インストール',
        'step1-body': 'pnpm でも npm でも。npx なら、インストールせずに一度だけ試せます。',
        'step2-title': 'プレビューを作成',
        'step2-body': 'ビルド済みの dist を渡すと、ローカルで暗号化してからアップロードします。',
        'step3-title': 'URLを送る',
        'step3-body': '発行されたURLを相手に送るだけ。48時間で自動的に失効します。',
        'features-label': '機能',
        'features-title': 'デプロイするほどじゃない。<br>でも<em>見せたい</em>ときのために。',
        'f1-title': 'アップロード前に暗号化',
        'f1-body': 'ファイルは AES-GCM でローカル暗号化してから送信。復号キーはURLフラグメントにあり、サーバー側はファイル名すら見えません。',
        'f2-title': 'ビルドも任せられる',
        'f2-body': 'dvyu preview が Astro / Vite / Storybook を自動判別。ビルダーに合わせて出力し、そのままアップロードします。',
        'f3-title': 'URLを変えずに更新',
        'f3-body': '修正したら dvyu update。同じURLのまま中身だけ差し替わるので、送ったリンクを貼り直す必要がありません。',
        'f4-title': '期限つきで、あと腐れなく',
        'f4-body': 'プレビューは48時間で自動失効。サポーターなら --permanence で、アクセスが30日途切れるまで残せます。',
        'f5-title': 'HTML 1枚からでも',
        'f5-body': 'dvyu create ./example.html のように、単一のHTMLファイルからもプレビューを作れます。ちょっとしたモックの共有に。',
