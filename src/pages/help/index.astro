      </div>
    </footer>
  </div>

  <div class="toast" id="toast" role="status" aria-live="polite">
    <Check size={16} strokeWidth={2.4} />
    <span id="toast-text"><span class="lang-block-ja">コピーしました</span><span class="lang-block-en">Copied</span></span>
  </div>

  <script>
    /* ------------------------------- Language ------------------------------- */
    const searchInput = document.getElementById('faq-search')
    let currentLang = localStorage.getItem('dvyu-lang') || (navigator.language && navigator.language.toLowerCase().startsWith('ja') ? 'ja' : 'en')

    function applyLanguage(lang) {
      currentLang = lang
      localStorage.setItem('dvyu-lang', lang)
      document.documentElement.lang = lang
      document.documentElement.classList.toggle('lang-ja', lang === 'ja')
      document.documentElement.classList.toggle('lang-en', lang === 'en')
      document.querySelectorAll('.lang-switch [data-lang]').forEach((el) => {
        el.classList.toggle('active', el.dataset.lang === lang)
      })
      searchInput.placeholder = lang === 'ja' ? '質問を検索' : 'Search questions'
      filterFaq(searchInput.value)
    }

    document.querySelectorAll('.lang-switch [data-lang]').forEach((el) => {
      el.addEventListener('click', () => applyLanguage(el.dataset.lang))
    })

    /* ------------------------------ FAQ search ------------------------------ */
    const faqCats = document.querySelectorAll('.faq-cat')
    const noResults = document.getElementById('no-results')

    function itemText(item) {
      const selector = currentLang === 'ja' ? '.lang-block-ja' : '.lang-block-en'
      let text = ''
      item.querySelectorAll(selector).forEach((block) => {
        text += ' ' + block.textContent
      })
      return text.toLowerCase()
    }

    function filterFaq(query) {
      const q = (query || '').trim().toLowerCase()
      let totalVisible = 0
      faqCats.forEach((cat) => {
        let catVisible = 0
        cat.querySelectorAll('.faq-item').forEach((item) => {
          const match = q === '' || itemText(item).includes(q)
          item.hidden = !match
          if (match) catVisible += 1
        })
        cat.hidden = catVisible === 0
        totalVisible += catVisible
      })
      noResults.hidden = totalVisible > 0
    }

    searchInput.addEventListener('input', () => filterFaq(searchInput.value))

    applyLanguage(currentLang)

    /* -------------------------- Copy + toast -------------------------- */
    const toast = document.getElementById('toast')
    let toastTimer = null

    function copyText(value) {
      if (!value) return
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(value).catch(() => {})
      }
      toast.classList.add('is-visible')
      if (toastTimer) clearTimeout(toastTimer)
      toastTimer = setTimeout(() => toast.classList.remove('is-visible'), 1600)
    }

    document.querySelectorAll('[data-copy]').forEach((button) => {
      button.addEventListener('click', () => copyText(button.dataset.copy))
    })

    /* --------------------- Inline command copy buttons --------------------- */
    const COPY_SVG =
      '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg>'

    document.querySelectorAll('.faq-body code').forEach((code) => {
      const text = code.textContent.trim()
      if (!text.startsWith('dvyu')) return
      if (code.closest('pre') || code.closest('[data-copy]') || code.closest('summary') || code.closest('button')) return
      const btn = document.createElement('button')
      btn.type = 'button'
      btn.className = 'code-copy'
      btn.setAttribute('aria-label', 'Copy')
      btn.innerHTML = COPY_SVG
      btn.addEventListener('click', () => copyText(text))
      code.after(btn)
    })

    /* ----------------------- Navbar scroll + progress ----------------------- */
    const navbar = document.getElementById('navbar')
    const navProgress = document.getElementById('nav-progress')
    let scrollFrame = 0

    function onScrollFrame() {
      scrollFrame = 0
      const y = window.scrollY
      navbar.classList.toggle('is-scrolled', y > 12)
      const docRange = document.documentElement.scrollHeight - window.innerHeight
      navProgress.style.transform = 'scaleX(' + (docRange > 0 ? Math.min(y / docRange, 1) : 0).toFixed(4) + ')'
    }

    window.addEventListener('scroll', () => {
      if (!scrollFrame) scrollFrame = requestAnimationFrame(onScrollFrame)
    }, { passive: true })
    onScrollFrame()
  </script>
</BaseLayout>
