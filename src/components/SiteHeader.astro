---
import LogoMark from './LogoMark.astro'

const GITHUB_URL = 'https://github.com/Drovyu/preview-cli'

const path = Astro.url.pathname
const isDocs = path === '/docs' || path.startsWith('/docs/')
const isHelp = path === '/help' || path.startsWith('/help/')
---

<header class="navbar" id="navbar">
  <a href="/" class="nav-logo"><LogoMark size={18} />dvyu</a>
  <nav class="nav-links">
    <a href="/#features"><span class="lang-block-ja">機能</span><span class="lang-block-en">Features</span></a>
    <a href="/#terminal-demo"><span class="lang-block-ja">コマンド</span><span class="lang-block-en">Commands</span></a>
    <a href="/#pricing"><span class="lang-block-ja">料金</span><span class="lang-block-en">Pricing</span></a>
    <a href="/#community"><span class="lang-block-ja">コミュニティ</span><span class="lang-block-en">Community</span></a>
    <a href="/docs" aria-current={isDocs ? 'page' : undefined}><span class="lang-block-ja">ドキュメント</span><span class="lang-block-en">Docs</span></a>
    <a href="/help" aria-current={isHelp ? 'page' : undefined}><span class="lang-block-ja">ヘルプ</span><span class="lang-block-en">Help</span></a>
  </nav>
  <div class="nav-right">
    <div class="lang-switch" role="group" aria-label="Language">
      <span data-lang="en">EN</span>
      <span data-lang="ja" class="active">JA</span>
    </div>
    <a class="nav-github" href={GITHUB_URL} target="_blank" rel="noreferrer" aria-label="GitHub">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.333-1.755-1.333-1.755-1.089-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.807 1.305 3.492.998.108-.776.417-1.305.76-1.605-2.665-.305-5.466-1.334-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path>
      </svg>
    </a>
    <button class="nav-menu-btn" id="nav-menu-btn" type="button" aria-expanded="false" aria-controls="navbar" aria-label="Menu">
      <span></span>
      <span></span>
    </button>
  </div>
  <div class="nav-progress" id="nav-progress" aria-hidden="true"></div>
</header>

<script>
  const navbar = document.getElementById('navbar')
  const menuButton = document.getElementById('nav-menu-btn')
  if (navbar && menuButton) {
    menuButton.addEventListener('click', () => {
      const open = navbar.classList.toggle('menu-open')
      menuButton.setAttribute('aria-expanded', String(open))
    })
    navbar.querySelectorAll('.nav-links a').forEach((link) => {
      link.addEventListener('click', () => {
        navbar.classList.remove('menu-open')
        menuButton.setAttribute('aria-expanded', 'false')
      })
    })
  }
</script>
